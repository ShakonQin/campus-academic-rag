# ============================================================
# 校园学术智能RAG检索系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际配置
# ============================================================

# ---- 应用配置 ----
APP_NAME=campus-academic-rag
APP_VERSION=1.0.0
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# ---- 日志配置 ----
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ---- 嵌入模型配置 ----
# 提供商: "api" (在线API，无需下载模型) 或 "local" (本地sentence-transformers)
EMBEDDING_PROVIDER=api

# API模式配置（推荐，无需下载模型）
# 支持OpenAI、智谱AI、硅基流动等OpenAI兼容接口
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_API_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_MODEL=text-embedding-3-small

# 本地模型配置（EMBEDDING_PROVIDER=local时使用）
# EMBEDDING_MODEL_PATH=./models/bge-base-zh-v1.5
# EMBEDDING_MODEL_NAME=BAAI/bge-base-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSION=768

# ---- 向量数据库配置 ----
VECTOR_DB_PATH=./data/vector_index
VECTOR_DB_COLLECTION=campus_academic

# ---- LLM配置 ----
# OpenAI兼容API（支持多种本地/云端LLM）
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# Anthropic API (可选)
# ANTHROPIC_API_KEY=your-anthropic-key
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ---- 检索配置 ----
RETRIEVAL_TOP_K=10
RETRIEVAL_SIMILARITY_THRESHOLD=0.5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# ---- 分片配置 ----
CHUNK_SENTENCES_PER_CHUNK=3
CHUNK_OVERLAP_SENTENCES=1
CHUNK_MAX_LENGTH=512

# ---- OCR配置（可选） ----
TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_LANG=chi_sim+eng

# ---- 安全配置 ----
# 启用合规检查
COMPLIANCE_CHECK_ENABLED=true
# 启用学术诚信审核
ACADEMIC_INTEGRITY_CHECK=true
